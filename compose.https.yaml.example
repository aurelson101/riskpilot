# Copier en compose.https.yaml puis adapter les chemins de certificats si besoin.
services:
  nginx:
    ports: !override
      - "80:80"
      - "443:443"
    volumes:
      - ./docker/nginx/https.conf.template:/etc/nginx/conf.d/default.conf:ro
      - ./docker/tls/fullchain.pem:/etc/nginx/tls/fullchain.pem:ro
      - ./docker/tls/privkey.pem:/etc/nginx/tls/privkey.pem:ro
      - ./docker/certbot:/var/www/certbot:ro
