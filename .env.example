APP_ENV=dev
APP_SECRET=change-this-local-secret
# URL publique exacte. Obligatoirement HTTPS en production et pour les callbacks OAuth.
APP_URL=http://localhost:8080
POSTGRES_DB=riskpilot
POSTGRES_USER=riskpilot
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql://riskpilot:change-this-database-password@postgres:5432/riskpilot?serverVersion=17&charset=utf8
REDIS_URL=redis://redis:6379
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
MAILER_DSN=smtp://mailpit:1025
JWT_PASSPHRASE=change-this-jwt-passphrase
VITE_API_URL=/api
# Limite globale du volume local ; à adapter au stockage objet en production.
DOCUMENT_STORAGE_QUOTA_BYTES=1073741824
# Laisser vide, ou lancer le profil Docker "antivirus" et utiliser clamav.
CLAMAV_HOST=
# Stockage objet S3/MinIO facultatif (vide = volume Docker local).
DOCUMENT_S3_ENDPOINT=
DOCUMENT_S3_BUCKET=
DOCUMENT_S3_REGION=eu-west-1
DOCUMENT_S3_ACCESS_KEY=
DOCUMENT_S3_SECRET_KEY=
